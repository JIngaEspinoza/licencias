{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { 
        "include": "mail/templates/**/*", 
        "watch": true 
      },
      { 
        "include": "templates/**/*", 
        "watch": true 
      }
    ],
    "watchAssets": true
  }
}
